#!/usr/bin/env bash
set -euo pipefail

EXECUTE="false"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --execute)
            EXECUTE="true"
            shift
            ;;
        *)
            break
            ;;
    esac
done

if [[ $# -ne 1 ]]; then
    echo "Usage: $0 [--execute] VERSION"
    exit 1
fi

VERSION="$1"
VERSION_REGEX='^[0-9]+\.[0-9]+\.[0-9]+(-rc\.[0-9]+)?$'
if [[ ! "$VERSION" =~ $VERSION_REGEX ]]; then
    echo "Version must match X.Y.Z or X.Y.Z-rc.N"
    exit 1
fi

git fetch --prune --tags origin +refs/heads/main:refs/remotes/origin/main

HEAD_COMMIT="$(git rev-parse HEAD)"
ORIGIN_MAIN_COMMIT="$(git rev-parse origin/main)"
if [[ "$HEAD_COMMIT" != "$ORIGIN_MAIN_COMMIT" ]]; then
    echo "Error: HEAD ($HEAD_COMMIT) is not the current origin/main ($ORIGIN_MAIN_COMMIT)."
    exit 1
fi

if [[ -n "$(git status --porcelain=v1 --untracked-files=all)" ]]; then
    echo "Error: git working directory is not clean. Commit or stash every change first."
    exit 1
fi

RELEASE_CRATES=(
    graft
    graft-sqlite
    graft-ext
    graft-tool
    graft-test
    graft-tracing
)

for crate in "${RELEASE_CRATES[@]}"; do
    CRATE_VERSION="$(cargo pkgid -p "$crate" | sed 's/.*#//')"
    if [[ "$CRATE_VERSION" != "$VERSION" ]]; then
        echo "Error: crate $crate is $CRATE_VERSION, expected $VERSION."
        exit 1
    fi
done

SQLPKG_VERSION="$(python3 -c 'import json; print(json.load(open("sqlpkg.json"))["version"])')"
if [[ "$SQLPKG_VERSION" != "$VERSION" ]]; then
    echo "Error: sqlpkg.json is $SQLPKG_VERSION, expected $VERSION."
    exit 1
fi

cargo metadata --locked --format-version 1 --no-deps >/dev/null
cargo check --workspace --all-targets --locked

TAG_NAME="v${VERSION}"
if git rev-parse --verify "refs/tags/$TAG_NAME" >/dev/null 2>&1; then
    echo "Error: local tag $TAG_NAME already exists."
    exit 1
fi
if git ls-remote --exit-code --tags origin "refs/tags/$TAG_NAME" >/dev/null 2>&1; then
    echo "Error: remote tag $TAG_NAME already exists."
    exit 1
fi

if [[ "$EXECUTE" == "true" ]]; then
    git tag -a "$TAG_NAME" -m "Release $TAG_NAME"
    git push origin "refs/tags/$TAG_NAME"
    echo "Pushed $TAG_NAME. The SQLite extension and CLI release workflow is now running."
else
    echo "Release checks passed. To create and push $TAG_NAME, run:"
    echo "  $0 --execute $VERSION"
fi
