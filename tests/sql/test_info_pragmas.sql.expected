-- exercise repository metadata pragmas through the SQLite extension
.connection 0
.open "file:app.db?vfs=graft"
.output /dev/null
.echo on

SELECT COUNT(*) AS account_count FROM accounts;
+---------------+
| account_count |
+---------------+
| 1000          |
+---------------+
SELECT COUNT(*) AS ledger_count FROM ledger;
+--------------+
| ledger_count |
+--------------+
| 1002         |
+--------------+

.echo off

SQLite Exit Code = 0
