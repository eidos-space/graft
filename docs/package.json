{
  "name": "docs",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "node -e \"const fs=require('node:fs'); for (const path of ['dist', '.astro']) fs.rmSync(path, { recursive: true, force: true })\" && astro build",
    "build:playground": "pnpm --dir ../web-demo run build:site && node scripts/embed-playground.mjs",
    "build:deploy": "pnpm build && pnpm build:playground",
    "deploy": "pnpm build:deploy && wrangler pages deploy",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/starlight": "^0.37.6",
    "@astrojs/starlight-docsearch": "^0.6.1",
    "astro": "^5.17.1",
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.1.1",
    "sharp": "^0.34.5",
    "starlight-package-managers": "^0.12.0",
    "starlight-theme-flexoki": "^0.2.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.61.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}
